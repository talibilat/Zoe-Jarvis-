# Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/<your-deployment>/chat/completions?api-version=<api-version>
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_RESOURCE=<your-azure-openai-resource-name>

# Optional OpenAI Platform fallback
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o

# Optional Claude/Anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Optional forced provider selection: azure_openai | openai | claude | ollama
LLM_PROVIDER=
# Optional LangGraph stream modes (comma-separated): values, updates, custom, messages, debug
STREAM_MODES=messages,updates

# Realtime endpoints
SESSIONS_URL=https://<your-resource>.openai.azure.com/openai/realtimeapi/sessions?api-version=2025-04-01-preview
WEBRTC_URL=https://<your-region>.realtimeapi-preview.ai.azure.com/v1/realtimertc
AZURE_OPENAI_REALTIME_VOICE=verse
AZURE_OPENAI_REALTIME_OUTPUT_RATE=24000
AZURE_REALTIME_PLAYBACK_RATE=1.5

# Gmail configuration
GMAIL_CLIENT_ID=<your-gmail-client-id>
GMAIL_CLIENT_SECRET=<your-gmail-client-secret>
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_TOKEN_BACKUP_FILE=token.json.bak

# Optional local runtime settings
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_REASONING=false
MIC_INDEX=
TRIGGER_WORD=zoe
CONVERSATION_TIMEOUT=30
USE_CONVERSATION_MEMORY=true
