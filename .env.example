# Azure OpenAI configuration (used by main.py and src/agent/app.py)
AZURE_OPENAI_ENDPOINT=https://<your-azure-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
# Example: 2024-08-01-preview. Use the version supported by your Azure OpenAI resource.
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>

# OpenAI Platform configuration (used if Azure is not fully configured)
OPENAI_API_KEY=
# Optional: override the OpenAI model name (defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Optional: select a microphone device index for SpeechRecognition (leave blank for default)
MIC_INDEX=
